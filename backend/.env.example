# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecommerce?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_for_production
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=5

# EmailJS Configuration (Backend usage)
EMAILJS_SERVICE_ID=service_xxxxx
EMAILJS_TEMPLATE_ID=template_xxxxx
EMAILJS_PUBLIC_KEY=user_xxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxx

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
